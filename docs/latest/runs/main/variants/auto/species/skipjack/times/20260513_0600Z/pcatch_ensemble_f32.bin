_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;_ַי;