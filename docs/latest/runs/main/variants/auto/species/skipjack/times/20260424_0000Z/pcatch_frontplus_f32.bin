=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表&=表