向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">向">