非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =非 =